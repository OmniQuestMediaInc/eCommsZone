# ─────────────────────────────────────────────
# eCommsZone — Environment Variable Reference
# Copy this file to .env and fill in real values.
# NEVER commit the .env file.
# ─────────────────────────────────────────────

# ── Node ──────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── listmonk ──────────────────────────────────
LISTMONK_BASE_URL=http://listmonk:9000
LISTMONK_USERNAME=admin
LISTMONK_PASSWORD=changeme

# ── PostgreSQL (shared by listmonk + API) ─────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ecommszone
POSTGRES_USER=ecommszone
POSTGRES_PASSWORD=changeme

# ── Redis (rate-limiting / queue) ─────────────
REDIS_URL=redis://redis:6379

# ── Brevo (formerly Sendinblue) ───────────────
BREVO_API_KEY=your-brevo-api-key-here
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your-brevo-smtp-login
BREVO_SMTP_PASSWORD=your-brevo-smtp-password
BREVO_SMS_SENDER=OmniQuest
BREVO_WHATSAPP_PHONE_NUMBER_ID=

# ── Tenant API Keys (generated per tenant) ────
# These are the keys each downstream service uses to authenticate
# against the eCommsZone gateway.
TENANT_KEY_CHATNOWZONE=
TENANT_KEY_REDROOMPLEASURES=
TENANT_KEY_REDROOMREWARDS=
TENANT_KEY_SENSYNC=
TENANT_KEY_CYRANO=
TENANT_KEY_OMNIQUEST_INTERNAL=

# ── Auth / JWT ────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=8h

# ── Logging ───────────────────────────────────
LOG_LEVEL=info

# ── Webhook Secrets ───────────────────────────
BREVO_WEBHOOK_SECRET=
LISTMONK_WEBHOOK_SECRET=
# =============================================================================
# eCommsZone — Environment Variables Example
# OmniQuest Media Inc. | PROGRAM_CONTROL: MKTP-WORK-004
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in ALL values marked with <CHANGE_ME>
#   3. NEVER commit the .env file — it is listed in .gitignore
#   4. Store production secrets in your VPS secret manager or CI/CD vault
# =============================================================================

# -----------------------------------------------------------------------------
# listmonk — Admin credentials
# -----------------------------------------------------------------------------
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASSWORD=<CHANGE_ME>

# -----------------------------------------------------------------------------
# PostgreSQL — Database credentials
# -----------------------------------------------------------------------------
POSTGRES_USER=listmonk
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_DB=listmonk

# -----------------------------------------------------------------------------
# Brevo (formerly Sendinblue) — SMTP relay
# Used by listmonk to deliver email via Brevo's SMTP gateway
# SMTP host:  smtp-relay.brevo.com  |  port: 587  |  TLS: STARTTLS
# -----------------------------------------------------------------------------
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=<CHANGE_ME>          # Your Brevo SMTP login (usually your account email)
BREVO_SMTP_PASSWORD=<CHANGE_ME>      # Brevo SMTP key (Settings → SMTP & API → SMTP)

# -----------------------------------------------------------------------------
# Brevo — REST API (used by TypeScript client for transactional email & SMS)
# Obtain from: https://app.brevo.com/settings/keys/api
# -----------------------------------------------------------------------------
BREVO_API_KEY=<CHANGE_ME>

# -----------------------------------------------------------------------------
# Brevo — SMS sender name (alphanumeric, max 11 chars, must be approved by Brevo)
# -----------------------------------------------------------------------------
BREVO_SMS_SENDER=OQMedia

# -----------------------------------------------------------------------------
# eCommsZone TypeScript client — base URL for the listmonk API
# In production this should point to your reverse-proxied domain, e.g.:
#   https://comms.yourdomain.ca
# In local development:
#   http://localhost:9000
# -----------------------------------------------------------------------------
ECOMMSZONE_BASE_URL=http://localhost:9000

# -----------------------------------------------------------------------------
# Application — default "from" address for outbound email
# -----------------------------------------------------------------------------
APP_FROM_EMAIL=noreply@yourdomain.ca
APP_FROM_NAME=OmniQuest Media

# -----------------------------------------------------------------------------
# Optional — Reverse proxy / TLS
# Set to "true" once you have a domain + SSL certificate configured.
# When true, listmonk should be accessed via HTTPS only.
# -----------------------------------------------------------------------------
ENABLE_HTTPS=false
