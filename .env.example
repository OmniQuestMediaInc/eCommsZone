# =============================================================================
# eCommsZone — Environment Variables (template)
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# ---- PostgreSQL ----
POSTGRES_DB=listmonk
POSTGRES_USER=listmonk
POSTGRES_PASSWORD=change-me-strong-password

# ---- listmonk ----
LISTMONK_PORT=9000
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASSWORD=change-me-strong-password
LISTMONK_PUBLIC_URL=https://comms.omniquestmedia.com

# ---- Brevo (delivery provider) ----
# Obtain from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-REPLACE_ME
# SMTP relay credentials (from https://app.brevo.com/settings/keys/smtp)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=REPLACE_ME@smtp-brevo.com
BREVO_SMTP_PASSWORD=REPLACE_ME
# Default verified sender (must be verified in Brevo)
BREVO_FROM_EMAIL=no-reply@omniquestmedia.com
BREVO_FROM_NAME=OmniQuest Media
# SMS sender ID (alphanumeric, max 11 chars in most regions)
BREVO_SMS_SENDER=OQMI

# ---- eCommsZone API (Node.js client / WP plugin auth) ----
# Shared secret used by OQMI services to call the eCommsZone API.
ECOMMSZONE_API_BASE_URL=https://comms.omniquestmedia.com
ECOMMSZONE_API_TOKEN=change-me-rotated-token

# ---- Observability (optional) ----
LOG_LEVEL=info
SENTRY_DSN=
